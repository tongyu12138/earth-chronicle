page {
  min-height: 100%;
  background: #071319;
  color: #ecf6f1;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

view, text, image, button, input, scroll-view {
  box-sizing: border-box;
}

button {
  font-family: inherit;
  margin: 0;
  padding: 0;
  line-height: normal;
  border-radius: 0;
  background: transparent;
  color: inherit;
}

button::after {
  border: 0;
}

.tap-card-active { opacity: .82; transform: scale(.985); }
.button-active { opacity: .86; transform: scale(.98); }

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.museum-page {
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 8% 5%, rgba(51, 126, 122, 0.14), transparent 32%),
    linear-gradient(180deg, #071319 0%, #091920 100%);
}

.section-kicker-global {
  display: block;
  color: #65d4c1;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  font-weight: 700;
}

.section-heading-global {
  display: block;
  margin-top: 14rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
}

.primary-button {
  min-height: 92rpx;
  padding: 0 34rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #70dcc5, #36a99f);
  color: #052019;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 50rpx rgba(54, 169, 159, 0.25);
}

.placeholder-visual {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 25% 25%, rgba(255,255,255,0.18), transparent 22%),
    linear-gradient(145deg, rgba(89, 176, 157, 0.45), rgba(20, 45, 58, 0.82) 58%, #09151b);
}

.placeholder-visual::after {
  content: '';
  position: absolute;
  inset: auto -10% -25% -10%;
  height: 58%;
  background: linear-gradient(165deg, transparent 20%, rgba(3, 12, 16, 0.72) 21%, rgba(10, 35, 38, 0.8) 52%, rgba(4, 15, 21, 0.95) 53%);
}
