:host { display: block; width: 100%; }
.media-shell { position: relative; overflow: hidden; width: 100%; background: #102831; }
.theme-ocean { background: radial-gradient(circle at 72% 28%, #2f6d78, #173b45 45%, #08151b 100%); }
.theme-rock { background: linear-gradient(145deg, #75604d, #283a3c 48%, #0a171c); }
.theme-ice { background: linear-gradient(145deg, #6da5b5, #284854 52%, #0a171c); }
.theme-volcanic { background: radial-gradient(circle at 30% 75%, #9e4a2a, #412c27 42%, #0a1519); }
.media-content, .media-skeleton, .media-fallback { position: absolute; inset: 0; width: 100%; height: 100%; }
.media-content { opacity: 0; transition: opacity .35s ease; }
.media-content.is-ready { opacity: 1; }
.media-skeleton { z-index: 2; background: linear-gradient(100deg, rgba(255,255,255,.02) 25%, rgba(255,255,255,.12) 45%, rgba(255,255,255,.02) 65%); background-size: 240% 100%; animation: media-shimmer 1.35s linear infinite; }
.media-fallback { display: flex; box-sizing: border-box; flex-direction: column; align-items: center; justify-content: center; padding: 28rpx; color: #b9d0d3; text-align: center; pointer-events: none; }
.fallback-orbit { font-size: 50rpx; color: #65d4c1; opacity: .75; }
.fallback-label { margin-top: 10rpx; font-size: 24rpx; font-weight: 700; }
.fallback-alt { margin-top: 8rpx; max-width: 84%; font-size: 20rpx; line-height: 1.45; color: #819ba0; }
.retry-button { margin-top: 18rpx; min-width: 0; padding: 0 24rpx; height: 54rpx; line-height: 54rpx; border: 1rpx solid rgba(255,255,255,.3); border-radius: 28rpx; background: rgba(5,18,23,.7); color: #eefafa; font-size: 21rpx; pointer-events: auto; }
.retry-button::after { border: 0; }
.media-type-badge { position: absolute; z-index: 4; top: 16rpx; left: 16rpx; padding: 8rpx 14rpx; border: 1rpx solid rgba(255,255,255,.22); border-radius: 22rpx; background: rgba(5,18,23,.78); color: #eaf6f3; font-size: 19rpx; line-height: 1; }
.preview-button { position: absolute; z-index: 4; right: 18rpx; bottom: 18rpx; min-width: 0; padding: 0 22rpx; height: 54rpx; line-height: 54rpx; border: 1rpx solid rgba(255,255,255,.26); border-radius: 30rpx; background: rgba(5,18,23,.72); color: #eefafa; font-size: 21rpx; }
.preview-button::after { border: 0; }
.media-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 10rpx 22rpx; padding: 14rpx 4rpx 0; color: #789096; font-size: 20rpx; line-height: 1.5; }
.media-caption { width: 100%; color: #9db2b3; }
.source-button { min-width: 0; margin: 0; padding: 0; background: transparent; color: #65d4c1; font-size: 20rpx; line-height: 1.5; text-decoration: underline; }
.source-button::after { border: 0; }
@keyframes media-shimmer { from { background-position: 160% 0; } to { background-position: -80% 0; } }
@media (prefers-reduced-motion: reduce) {
  .media-content { transition: none; }
  .media-skeleton { animation: none; background: rgba(255,255,255,.07); }
}
