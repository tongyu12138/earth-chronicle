<page-meta page-style="background:#071319" />
<view class="museum-page search-page safe-bottom">
  <view class="search-header"><text class="section-kicker-global">SEARCH THE ARCHIVE</text><text class="search-title">搜索地球史</text><view class="search-box"><text>⌕</text><input focus="true" value="{{query}}" bindinput="onInput" placeholder="时期、事件、古生物、学名或标签" placeholder-class="placeholder" /><button wx:if="{{query}}" bindtap="clearQuery" aria-label="清空搜索词">×</button></view></view>
  <view wx:if="{{searched}}" class="search-body">
    <text class="result-count">当前显示 {{total}} 条匹配结果</text>
    <view wx:if="{{periodResults.length}}" class="result-section"><text class="result-type">时期 · {{periodResults.length}}</text><view class="result-card" wx:for="{{periodResults}}" wx:key="id" hover-class="tap-card-active" bindtap="openResult" data-type="period" data-id="{{item.id}}"><view class="result-thumb"><media-image media-id="{{item.mediaId}}" variant="thumbnail" ratio="4:3" alt="{{item.name}}时期封面" /></view><view class="result-info"><text class="type-label">{{item.typeLabel}}</text><text class="result-name">{{item.name}}</text><text class="result-meta">{{item.meta}}</text><text class="result-copy">{{item.copy}}</text></view><text class="result-arrow">›</text></view></view>
    <view wx:if="{{eventResults.length}}" class="result-section"><text class="result-type">事件 · {{eventResults.length}}</text><view class="result-card" wx:for="{{eventResults}}" wx:key="id" hover-class="tap-card-active" bindtap="openResult" data-type="event" data-id="{{item.id}}"><view class="result-thumb"><media-image media-id="{{item.mediaId}}" variant="thumbnail" ratio="4:3" alt="{{item.name}}事件图片" /></view><view class="result-info"><text class="type-label">{{item.typeLabel}}</text><text class="result-name">{{item.name}}</text><text class="result-meta">{{item.meta}}</text><text class="result-copy">{{item.copy}}</text></view><text class="result-arrow">›</text></view></view>
    <view wx:if="{{creatureResults.length}}" class="result-section"><text class="result-type">古生物 · {{creatureResults.length}}</text><view class="result-card" wx:for="{{creatureResults}}" wx:key="id" hover-class="tap-card-active" bindtap="openResult" data-type="creature" data-id="{{item.id}}"><view class="result-thumb"><media-image media-id="{{item.mediaId}}" variant="thumbnail" ratio="4:3" alt="{{item.name}}科学图片" /></view><view class="result-info"><text class="type-label">{{item.typeLabel}}</text><text class="result-name">{{item.name}}</text><text class="latin">{{item.latin}}</text><text class="result-meta">{{item.meta}}</text><text class="result-copy">{{item.copy}}</text></view><text class="result-arrow">›</text></view></view>
    <view wx:if="{{total === 0}}" class="no-result"><text>没有找到匹配内容</text><text>可尝试“灭绝”“海洋”“鲸”“人工智能”或拉丁学名。</text></view>
  </view>
  <view wx:else class="search-suggestions"><text>可以试试</text><view><button data-value="灭绝" bindtap="onSuggestion">灭绝</button><button data-value="海洋" bindtap="onSuggestion">海洋</button><button data-value="人类" bindtap="onSuggestion">人类</button><button data-value="人工智能" bindtap="onSuggestion">人工智能</button></view></view>
</view>
