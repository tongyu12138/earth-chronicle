.search-page { padding-bottom: 60rpx; }
.search-header { padding: 72rpx 32rpx 34rpx; }
.search-title { display: block; margin-top: 10rpx; font-size: 58rpx; font-weight: 900; }
.search-box { height: 96rpx; margin-top: 32rpx; padding: 0 22rpx; border-radius: 24rpx; background: rgba(255,255,255,.06); border: 1rpx solid rgba(255,255,255,.1); display: flex; align-items: center; gap: 15rpx; color: #6f888c; }
.search-box input { flex: 1; height: 100%; color: #e1ebe9; font-size: 24rpx; }
.search-box button { width: 48rpx; height: 48rpx; border-radius: 50%; background: rgba(255,255,255,.08); display: flex; align-items: center; justify-content: center; }
.placeholder { color: #5b7276; }
.search-body { padding: 0 32rpx; }
.result-count { display: block; color: #687f83; font-size: 20rpx; }
.result-section { margin-top: 42rpx; }
.result-type { display: block; color: #66d1bf; font-size: 20rpx; font-weight: 800; letter-spacing: 2rpx; }
.result-card { margin-top: 14rpx; padding: 22rpx; border-radius: 22rpx; background: rgba(255,255,255,.045); border: 1rpx solid rgba(255,255,255,.07); display: flex; align-items: flex-start; gap: 18rpx; }
.type-icon { flex: 0 0 52rpx; width: 52rpx; height: 52rpx; border-radius: 15rpx; background: rgba(101,212,193,.11); color: #6ed2c0; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }
.result-card > view:nth-child(2) { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.result-card > view:nth-child(2) text:first-child { font-size: 27rpx; font-weight: 780; }
.result-card > view:nth-child(2) text:nth-child(2) { margin-top: 7rpx; color: #c7a86d; font-size: 18rpx; }
.result-card > view:nth-child(2) text:last-child { margin-top: 12rpx; color: #84999c; font-size: 20rpx; line-height: 1.5; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.result-card > text { color: #5f777b; font-size: 28rpx; }
.latin { font-style: italic; }
.no-result { padding: 130rpx 30rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; color: #70878a; text-align: center; font-size: 22rpx; }
.no-result text:first-child { color: #c2d0ce; font-size: 30rpx; font-weight: 750; }
.search-suggestions { padding: 40rpx 32rpx; color: #708589; font-size: 21rpx; }
.search-suggestions view { margin-top: 16rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.search-suggestions button { padding: 14rpx 22rpx; border-radius: 999rpx; background: rgba(255,255,255,.05); color: #91a5a7; font-size: 20rpx; }
