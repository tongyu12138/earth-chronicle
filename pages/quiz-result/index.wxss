.result-page { padding: 28rpx 0 76rpx; }
.identity-poster { position: relative; margin: 0 26rpx; padding: 30rpx 30rpx 34rpx; overflow: hidden; border: 2rpx solid; border-radius: 42rpx; box-shadow: 0 28rpx 70rpx rgba(0,0,0,.3); }
.identity-poster::before { content: ''; position: absolute; width: 420rpx; height: 420rpx; right: -180rpx; top: -170rpx; border: 2rpx solid currentColor; border-radius: 50%; opacity: .09; }
.identity-topline { position: relative; display: flex; justify-content: space-between; font-size: 20rpx; font-weight: 850; letter-spacing: 3rpx; opacity: .72; }
.type-heading { position: relative; margin-top: 24rpx; display: flex; flex-direction: column; }
.type-code { font-size: 74rpx; line-height: 1; font-weight: 950; letter-spacing: 7rpx; }
.type-name { margin-top: 10rpx; font-size: 46rpx; line-height: 1.15; font-weight: 900; }
.type-tagline { margin-top: 12rpx; font-size: 24rpx; line-height: 1.45; font-weight: 700; opacity: .78; }
.identity-art { position: relative; width: 390rpx; height: 390rpx; margin: 32rpx auto 0; overflow: hidden; border: 10rpx solid; border-radius: 50%; background: rgba(255,255,255,.34); box-shadow: 0 22rpx 45rpx rgba(0,0,0,.2); }
.identity-art media-image { width: 100%; height: 100%; }
.identity-species { position: relative; display: block; margin-top: 26rpx; font-size: 50rpx; line-height: 1.15; text-align: center; font-weight: 950; }
.identity-title { position: relative; display: block; margin-top: 8rpx; font-size: 27rpx; line-height: 1.4; text-align: center; font-weight: 850; }
.identity-line { position: relative; display: block; max-width: 590rpx; margin: 14rpx auto 0; font-size: 25rpx; line-height: 1.65; text-align: center; font-weight: 650; }
.axis-chips { position: relative; margin-top: 26rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; }
.axis-chips text { padding: 14rpx 12rpx; border-radius: 14rpx; background: rgba(255,255,255,.52); font-size: 22rpx; text-align: center; font-weight: 800; }
.match-level { position: relative; margin: 24rpx auto 0; padding: 14rpx 22rpx; border: 2rpx solid currentColor; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.match-level text:first-child { font-size: 23rpx; font-weight: 900; }
.match-level text:last-child { font-size: 20rpx; opacity: .72; }
.result-body { padding: 0 32rpx; }
.shared-note { margin-top: 28rpx; padding: 22rpx 24rpx; border-left: 5rpx solid #65d4c1; background: rgba(101,212,193,.08); color: #9bb4b1; font-size: 22rpx; line-height: 1.65; }
.quadrant-section, .result-section { padding-top: 78rpx; }
.quadrant-grid { margin-top: 28rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 14rpx; }
.quadrant-item { min-height: 190rpx; padding: 22rpx; border-top: 6rpx solid #65d4c1; border-radius: 18rpx; background: rgba(255,255,255,.055); display: flex; flex-direction: column; }
.quadrant-item text:first-child { color: #e7efec; font-size: 23rpx; font-weight: 850; }
.quadrant-item text:last-child { margin-top: 13rpx; color: #9fb2af; font-size: 22rpx; line-height: 1.58; }
.match-chain { margin-top: 30rpx; }
.chain-row { padding: 8rpx 0 8rpx 22rpx; border-left: 5rpx solid #65d4c1; display: flex; flex-direction: column; }
.chain-label { color: #6fd3c1; font-size: 21rpx; font-weight: 900; }
.chain-copy { margin-top: 10rpx; color: #d6e1de; font-size: 25rpx; line-height: 1.68; }
.chain-arrow { display: block; margin: 14rpx 0 14rpx 20rpx; color: #d7b66f; font-size: 32rpx; line-height: 1; }
.choice-receipts { margin-top: 26rpx; padding-top: 8rpx; border-top: 1rpx solid rgba(255,255,255,.08); }
.choice-receipts > view { padding: 18rpx 0; display: flex; flex-direction: column; gap: 7rpx; }
.choice-receipts text:first-child { color: #6ecfbe; font-size: 20rpx; font-weight: 850; }
.choice-receipts text:nth-child(2) { color: #e6edeb; font-size: 23rpx; line-height: 1.5; font-weight: 750; }
.choice-receipts text:last-child { color: #879d9a; font-size: 21rpx; line-height: 1.5; }
.takeaway-section { display: flex; flex-direction: column; }
.takeaway-row { padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.08); display: grid; grid-template-columns: 138rpx 1fr; gap: 16rpx; }
.takeaway-row text:first-child { color: #d7b76f; font-size: 22rpx; font-weight: 850; }
.takeaway-row text:last-child { color: #a9bbb8; font-size: 24rpx; line-height: 1.7; }
.science-intro { display: block; margin-top: 18rpx; color: #829997; font-size: 22rpx; line-height: 1.6; }
.science-preview-list { margin-top: 24rpx; }
.science-preview-list > view { padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.08); display: flex; flex-direction: column; gap: 10rpx; }
.science-preview-list text:first-child { color: #d7b770; font-size: 21rpx; font-weight: 850; }
.science-preview-list text:last-child { color: #adbfbc; font-size: 24rpx; line-height: 1.68; }
.evidence-boundary { margin-top: 26rpx; padding: 24rpx; border-left: 5rpx solid #d8b66d; background: rgba(216,182,109,.07); display: flex; flex-direction: column; gap: 12rpx; }
.evidence-boundary text:first-child { color: #e0bd76; font-size: 22rpx; font-weight: 900; }
.evidence-boundary text:last-child { color: #a5b5b1; font-size: 22rpx; line-height: 1.68; }
.source-links { margin-top: 18rpx; }
.source-links button { min-height: 72rpx; margin-top: 10rpx; padding: 14rpx 18rpx; border-radius: 12rpx; background: rgba(101,212,193,.055); color: #91aaa7; font-size: 20rpx; display: flex; align-items: center; text-align: left; }
.source-links button text:first-child { flex: 1; }
.source-links button text:last-child { margin-left: 14rpx; color: #65d2bf; font-weight: 850; }
.science-button { margin-top: 28rpx; }
.calculation-section { padding-top: 58rpx; }
.calculation-toggle { width: 100%; min-height: 82rpx; padding: 0 24rpx; border: 1rpx solid rgba(255,255,255,.12); border-radius: 18rpx; color: #a9bbb8; font-size: 23rpx; display: flex; align-items: center; }
.calculation-toggle text:first-child { flex: 1; text-align: left; font-weight: 850; }
.calculation-toggle text:last-child { color: #67d0be; }
.calculation-detail { padding: 24rpx 4rpx 0; }
.entertainment-score { display: block; color: #d9ba76; font-size: 24rpx; font-weight: 850; }
.calculation-note { display: block; margin-top: 12rpx; color: #7f9694; font-size: 21rpx; line-height: 1.6; }
.dimension-groups { margin-top: 24rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 22rpx 16rpx; }
.dimension-groups > view > view:first-child { display: flex; color: #8fa4a1; font-size: 20rpx; }
.dimension-groups > view > view:first-child text:first-child { flex: 1; color: #c8d4d1; font-weight: 800; }
.result-track { height: 8rpx; margin-top: 10rpx; overflow: hidden; border-radius: 8rpx; background: rgba(255,255,255,.08); }
.result-track view { height: 100%; }
.similar-grid { margin-top: 28rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 15rpx; }
.similar-grid > view { padding-bottom: 22rpx; overflow: hidden; border-radius: 20rpx; background: rgba(255,255,255,.05); }
.similar-art { height: 210rpx; }
.similar-heading { margin: 17rpx 17rpx 0; display: flex; align-items: center; gap: 10rpx; }
.similar-heading text:first-child { flex: 1; color: #e1eae7; font-size: 25rpx; line-height: 1.3; font-weight: 850; }
.similar-heading text:last-child { padding: 6rpx 9rpx; border-radius: 8rpx; background: rgba(101,212,193,.1); color: #66cfbd; font-size: 20rpx; font-weight: 900; }
.similar-shared, .similar-difference { display: -webkit-box; margin: 12rpx 17rpx 0; overflow: hidden; color: #92a6a3; font-size: 20rpx; line-height: 1.5; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.similar-difference { color: #758b89; }
.result-actions { padding-top: 64rpx; display: flex; flex-direction: column; gap: 14rpx; }
.secondary-button, .share-button { width: 100%; min-height: 86rpx; border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,.12); color: #a4b7b4; font-size: 23rpx; display: flex; align-items: center; justify-content: center; }
.share-button { border-color: rgba(101,212,193,.42); background: rgba(101,212,193,.1); color: #70d4c2; font-weight: 850; }
.secondary-share { background: transparent; border-color: rgba(255,255,255,.13); color: #9cb0ad; }
.poster-canvas { position: fixed; left: -2000px; top: 0; opacity: 0; pointer-events: none; }
.result-disclaimer { display: block; margin-top: 32rpx; color: #586f70; font-size: 20rpx; line-height: 1.55; text-align: center; }
@media (max-width: 340px) {
  .quadrant-grid, .similar-grid { grid-template-columns: 1fr; }
  .quadrant-item { min-height: 0; }
  .match-level { align-items: flex-start; flex-direction: column; border-radius: 18rpx; }
}
@media (prefers-reduced-motion: reduce) {
  .identity-poster, .identity-art { animation: none; transition: none; }
}
