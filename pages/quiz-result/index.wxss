.result-page { padding-bottom: 70rpx; }
.result-hero { height: 940rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.result-main-media { position: absolute; z-index: 1; inset: 0; width: 100%; }
.reveal-rays { position: absolute; width: 760rpx; height: 760rpx; border-radius: 50%; background: repeating-conic-gradient(from 0deg, rgba(101,212,193,.08) 0 8deg, transparent 8deg 19deg); animation: slowRotate 22s linear infinite; }
.result-overlay { position: absolute; z-index: 2; inset: 0; background: linear-gradient(180deg, transparent 28%, rgba(7,19,25,.18) 48%, #071319 94%); }
.result-hero-content { position: absolute; z-index: 3; left: 32rpx; right: 32rpx; bottom: 58rpx; display: flex; flex-direction: column; align-items: center; text-align: center; }
.result-kicker { color: #69d3c1; font-size: 18rpx; letter-spacing: 5rpx; }
.identity-label { margin-top: 18rpx; color: #8fa3a5; font-size: 22rpx; }
.identity-name { margin-top: 8rpx; font-size: 78rpx; line-height: 1.1; font-weight: 900; }
.identity-latin { margin-top: 8rpx; color: #859b9e; font-size: 23rpx; font-style: italic; }
.identity-title { margin-top: 18rpx; color: #e0bd78; font-size: 28rpx; font-weight: 750; }
.identity-punchline { max-width: 620rpx; margin-top: 12rpx; overflow: hidden; color: #9eb1af; font-size: 20rpx; line-height: 1.55; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
.match-ring { width: 122rpx; height: 122rpx; margin-top: 28rpx; border-radius: 50%; border: 4rpx solid rgba(101,212,193,.55); background: rgba(7,19,25,.55); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.match-ring text:first-child { font-size: 30rpx; font-weight: 900; }
.match-ring text:last-child { margin-top: 3rpx; color: #73a09a; font-size: 16rpx; }
.shared-score-note { margin-top: 26rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: rgba(7,19,25,.66); color: #8da4a4; font-size: 19rpx; }
.result-body { padding: 0 32rpx; }
.shared-note { padding: 22rpx; border-radius: 18rpx; background: rgba(101,212,193,.09); color: #86a7a3; font-size: 20rpx; line-height: 1.6; }
.trait-chips { margin-top: 28rpx; display: flex; justify-content: center; flex-wrap: wrap; gap: 12rpx; }
.trait-chips text { padding: 12rpx 18rpx; border-radius: 999rpx; background: rgba(101,212,193,.12); color: #73d2c1; font-size: 20rpx; }
.why-card { margin-top: 30rpx; padding: 32rpx; border-radius: 28rpx; background: rgba(255,255,255,.045); border: 1rpx solid rgba(255,255,255,.08); display: flex; flex-direction: column; }
.why-card .why-heading { color: #e0bb75; font-size: 22rpx; font-weight: 800; }
.why-card .why-summary { margin-top: 17rpx; color: #bdccca; font-size: 25rpx; line-height: 1.75; }
.match-steps { margin-top: 24rpx; display: flex; flex-direction: column; gap: 14rpx; }
.match-steps > view { padding: 21rpx; border-radius: 18rpx; background: rgba(101,212,193,.055); display: flex; flex-direction: column; gap: 9rpx; }
.match-steps text:first-child { color: #6fd0bf; font-size: 19rpx; font-weight: 850; }
.match-steps text:last-child { color: #9eafad; font-size: 22rpx; line-height: 1.65; }
.result-section { padding-top: 92rpx; }
.impact-section { padding-top: 66rpx; }
.impact-summary { display: block; margin-top: 20rpx; color: #d6b36f; font-size: 22rpx; }
.impact-list { margin-top: 22rpx; display: flex; flex-direction: column; gap: 12rpx; }
.impact-list > view { padding: 22rpx; border-radius: 20rpx; background: rgba(255,255,255,.04); display: flex; flex-direction: column; gap: 9rpx; }
.impact-list text:first-child { color: #6bcdbc; font-size: 19rpx; font-weight: 800; }
.impact-list .choice-quote { color: #e2e9e6; font-size: 23rpx; line-height: 1.55; font-weight: 750; }
.impact-list .choice-reading { color: #9bafad; font-size: 21rpx; line-height: 1.6; }
.strength-list { margin-top: 28rpx; display: flex; flex-direction: column; gap: 12rpx; }
.strength-list > view { padding: 22rpx; border-radius: 20rpx; background: rgba(255,255,255,.04); display: grid; grid-template-columns: 42rpx 1fr; gap: 12rpx; }
.strength-list text:first-child { color: #69cfbd; font-size: 25rpx; font-weight: 900; }
.strength-list text:last-child { color: #a8bab8; font-size: 21rpx; line-height: 1.6; }
.caution-card { margin-top: 18rpx; padding: 26rpx; border-radius: 22rpx; background: rgba(203,133,82,.08); border: 1rpx solid rgba(203,133,82,.18); display: flex; flex-direction: column; gap: 12rpx; }
.caution-card text:first-child { color: #ddb06f; font-size: 21rpx; font-weight: 850; }
.caution-card text:not(:first-child) { color: #9fa9a2; font-size: 21rpx; line-height: 1.65; }
.result-copy { display: block; margin-top: 25rpx; color: #a7b8b8; font-size: 26rpx; line-height: 1.85; }
.secondary-copy { margin-top: 14rpx; color: #809797; font-size: 22rpx; }
.science-fact { margin-top: 25rpx; padding: 25rpx; border-left: 4rpx solid #68d1bf; background: rgba(255,255,255,.035); display: flex; flex-direction: column; gap: 11rpx; color: #85999b; font-size: 21rpx; line-height: 1.6; }
.science-fact text:first-child { color: #c0cfcd; font-weight: 750; }
.result-evidence-list { margin-top: 28rpx; display: flex; flex-direction: column; gap: 16rpx; }
.result-evidence-list > view { padding: 25rpx; border-radius: 20rpx; background: rgba(255,255,255,.04); border: 1rpx solid rgba(255,255,255,.07); display: flex; flex-direction: column; gap: 10rpx; }
.result-evidence-list text:first-child { color: #d8bd7f; font-size: 20rpx; font-weight: 800; }
.result-evidence-list text:not(:first-child) { color: #94aaa8; font-size: 20rpx; line-height: 1.58; }
.result-source-list { margin-top: 18rpx; display: flex; flex-direction: column; gap: 10rpx; }
.result-source-list button { min-height: 68rpx; padding: 14rpx 20rpx; border-radius: 16rpx; background: rgba(101,212,193,.06); color: #7faaa4; font-size: 18rpx; display: flex; align-items: center; text-align: left; }
.result-source-list button text:first-child { flex: 1; }
.result-source-list button text:last-child { color: #66c9b8; font-weight: 750; }
.dimension-groups { margin-top: 30rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 18rpx; }
.dimension-groups > view { min-height: 130rpx; padding: 22rpx; border-radius: 20rpx; background: rgba(255,255,255,.035); }
.dimension-groups > view > view:first-child { display: flex; flex-direction: column; gap: 6rpx; }
.dimension-groups > view > view:first-child text:first-child { color: #dce8e6; font-size: 23rpx; font-weight: 750; }
.dimension-groups > view > view:first-child text:last-child { color: #789092; font-size: 18rpx; }
.profile-toggle { width: 100%; min-height: 72rpx; margin-top: 22rpx; border: 1rpx solid rgba(101,212,193,.28); border-radius: 999rpx; color: #6fd1c0; font-size: 21rpx; }
.result-bars { margin-top: 30rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 22rpx; }
.result-bars > view > view:first-child { display: flex; color: #809598; font-size: 18rpx; }
.result-bars > view > view:first-child text:first-child { flex: 1; }
.result-track { height: 8rpx; margin-top: 9rpx; border-radius: 9rpx; background: rgba(255,255,255,.07); overflow: hidden; }
.result-track view { height: 100%; background: linear-gradient(90deg,#419e94,#72dbc7); }
.similar-grid { margin-top: 30rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 15rpx; }
.similar-grid > view { min-height: 430rpx; padding-bottom: 20rpx; overflow: hidden; border-radius: 22rpx; background: rgba(255,255,255,.045); display: flex; flex-direction: column; }
.similar-art { height: 210rpx; display: flex; align-items: center; justify-content: center; }
.similar-art text { position: relative; z-index: 2; color: rgba(255,255,255,.42); font-size: 27rpx; font-weight: 800; }
.similar-grid .similar-name { min-height: 64rpx; margin: 17rpx 18rpx 0; overflow: hidden; color: #e4eeec; font-size: 25rpx; line-height: 1.3; font-weight: 750; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.similar-grid .similar-latin { min-height: 42rpx; margin: 5rpx 18rpx 0; overflow: hidden; color: #71878a; font-size: 17rpx; line-height: 1.25; font-style: italic; font-weight: 400; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.similar-grid .similar-note { margin: 12rpx 18rpx 0; color: #8da4a3; font-size: 18rpx; line-height: 1.5; font-weight: 400; }
.result-actions { padding-top: 70rpx; display: flex; flex-direction: column; gap: 16rpx; }
.secondary-button, .share-button { width: 100%; min-height: 86rpx; border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,.1); color: #9cafad; font-size: 23rpx; display: flex; align-items: center; justify-content: center; }
.share-button { border-color: rgba(101,212,193,.35); color: #69d0be; }
.secondary-share { border-color: rgba(255,255,255,.12); color: #91a7a5; }
.poster-canvas { position: fixed; left: -2000px; top: 0; opacity: 0; pointer-events: none; }
.result-disclaimer { display: block; margin-top: 34rpx; color: #536a6e; font-size: 18rpx; line-height: 1.55; text-align: center; }
@keyframes slowRotate { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) { .reveal-rays { animation: none; } }
