.result-page { padding-bottom: 70rpx; }
.result-hero { height: 940rpx; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.result-main-media { position: absolute; z-index: 1; inset: 0; width: 100%; opacity: 0; animation: mediaReveal .8s .35s ease-out forwards; }
.reveal-rays { position: absolute; width: 760rpx; height: 760rpx; border-radius: 50%; background: repeating-conic-gradient(from 0deg, rgba(101,212,193,.08) 0 8deg, transparent 8deg 19deg); animation: slowRotate 22s linear infinite; }
.result-initial { position: relative; z-index: 1; color: rgba(255,255,255,.18); font-size: 280rpx; font-weight: 900; animation: revealScale 1s ease-out both; }
.result-overlay { position: absolute; z-index: 2; inset: 0; background: linear-gradient(180deg, transparent 28%, rgba(7,19,25,.18) 48%, #071319 94%); }
.result-hero-content { position: absolute; z-index: 3; left: 32rpx; right: 32rpx; bottom: 58rpx; display: flex; flex-direction: column; align-items: center; text-align: center; }
.result-kicker { color: #69d3c1; font-size: 18rpx; letter-spacing: 5rpx; }
.identity-label { margin-top: 18rpx; color: #8fa3a5; font-size: 22rpx; }
.identity-name { margin-top: 8rpx; font-size: 78rpx; line-height: 1.1; font-weight: 900; }
.identity-latin { margin-top: 8rpx; color: #859b9e; font-size: 23rpx; font-style: italic; }
.identity-title { margin-top: 18rpx; color: #e0bd78; font-size: 28rpx; font-weight: 750; }
.match-ring { width: 122rpx; height: 122rpx; margin-top: 28rpx; border-radius: 50%; border: 4rpx solid rgba(101,212,193,.55); background: rgba(7,19,25,.55); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.match-ring text:first-child { font-size: 30rpx; font-weight: 900; }
.match-ring text:last-child { margin-top: 3rpx; color: #73a09a; font-size: 16rpx; }
.result-body { padding: 0 32rpx; }
.shared-note { padding: 22rpx; border-radius: 18rpx; background: rgba(101,212,193,.09); color: #86a7a3; font-size: 20rpx; line-height: 1.6; }
.trait-chips { margin-top: 28rpx; display: flex; justify-content: center; flex-wrap: wrap; gap: 12rpx; }
.trait-chips text { padding: 12rpx 18rpx; border-radius: 999rpx; background: rgba(101,212,193,.12); color: #73d2c1; font-size: 20rpx; }
.why-card { margin-top: 30rpx; padding: 32rpx; border-radius: 28rpx; background: rgba(255,255,255,.045); border: 1rpx solid rgba(255,255,255,.08); display: flex; flex-direction: column; }
.why-card text:first-child { color: #e0bb75; font-size: 21rpx; font-weight: 800; }
.why-card text:last-child { margin-top: 17rpx; color: #afbfbe; font-size: 25rpx; line-height: 1.8; }
.why-card text:nth-child(n+3) { margin-top: 10rpx; color: #8fa5a4; font-size: 22rpx; line-height: 1.6; }
.result-guidance { margin-top: 18rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 14rpx; }
.result-guidance>view { padding: 24rpx; border-radius: 22rpx; background: rgba(255,255,255,.035); display: flex; flex-direction: column; gap: 10rpx; color: #8fa5a4; font-size: 21rpx; line-height: 1.55; }
.result-guidance>view>text:first-child { color: #d9e6e3; font-weight: 750; }
.result-section { padding-top: 92rpx; }
.result-copy { display: block; margin-top: 25rpx; color: #a7b8b8; font-size: 26rpx; line-height: 1.85; }
.science-fact { margin-top: 25rpx; padding: 25rpx; border-left: 4rpx solid #68d1bf; background: rgba(255,255,255,.035); display: flex; flex-direction: column; gap: 11rpx; color: #85999b; font-size: 21rpx; line-height: 1.6; }
.science-fact text:first-child { color: #c0cfcd; font-weight: 750; }
.result-bars { margin-top: 30rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 22rpx; }
.result-bars > view > view:first-child { display: flex; color: #809598; font-size: 18rpx; }
.result-bars > view > view:first-child text:first-child { flex: 1; }
.result-track { height: 8rpx; margin-top: 9rpx; border-radius: 9rpx; background: rgba(255,255,255,.07); overflow: hidden; }
.result-track view { height: 100%; background: linear-gradient(90deg,#419e94,#72dbc7); }
.similar-grid { margin-top: 30rpx; display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 15rpx; }
.similar-grid > view { padding-bottom: 20rpx; overflow: hidden; border-radius: 22rpx; background: rgba(255,255,255,.045); display: flex; flex-direction: column; }
.similar-art { height: 210rpx; display: flex; align-items: center; justify-content: center; }
.similar-art text { position: relative; z-index: 2; color: rgba(255,255,255,.42); font-size: 27rpx; font-weight: 800; }
.similar-grid > view > text { margin: 17rpx 18rpx 0; font-size: 25rpx; font-weight: 750; }
.similar-grid > view > text:last-child { margin-top: 5rpx; color: #71878a; font-size: 17rpx; font-style: italic; font-weight: 400; }
.result-actions { padding-top: 70rpx; display: flex; flex-direction: column; gap: 16rpx; }
.secondary-button, .share-button { width: 100%; min-height: 86rpx; border-radius: 999rpx; border: 1rpx solid rgba(255,255,255,.1); color: #9cafad; font-size: 23rpx; display: flex; align-items: center; justify-content: center; }
.share-button { border-color: rgba(101,212,193,.35); color: #69d0be; }
.result-disclaimer { display: block; margin-top: 34rpx; color: #536a6e; font-size: 18rpx; line-height: 1.55; text-align: center; }
@keyframes slowRotate { to { transform: rotate(360deg); } }
@keyframes revealScale { from { opacity: 0; transform: scale(.75); filter: blur(20rpx); } to { opacity: 1; transform: scale(1); filter: blur(0); } }
@keyframes mediaReveal { from { opacity: 0; filter: blur(18rpx); transform: scale(1.06); } to { opacity: 1; filter: blur(0); transform: scale(1); } }
