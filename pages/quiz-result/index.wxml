<page-meta page-style="background:#071319" />
<view wx:if="{{primary}}" class="museum-page result-page safe-bottom">
  <view class="identity-poster" style="{{identityStyle}}">
    <view class="identity-topline">
      <text>PALEO CODE</text>
      <text>{{paleoType.family === 'explorer' ? '探索家族' : paleoType.family === 'builder' ? '建造家族' : paleoType.family === 'guardian' ? '守护家族' : '连接家族'}}</text>
    </view>
    <view class="type-heading">
      <text class="type-code">{{paleoType.code}}</text>
      <text class="type-name">{{paleoType.nameCn}}</text>
      <text class="type-tagline">{{paleoType.tagline}}</text>
    </view>
    <view class="identity-art" style="border-color:{{paleoType.color}}">
      <media-image
        id="primaryMedia"
        class="primary-media"
        media-id="{{primary.mediaId}}"
        variant="hero"
        ratio="4:3"
        mode="aspectFit"
        alt="{{primary.imageAlt}}"
        placeholder-theme="rock"
        lazy-load="false"
        show-caption="{{false}}"
        show-meta="{{false}}"
        show-source="{{false}}"
        bindready="handlePrimaryMediaReady"
        binderror="handlePrimaryMediaError"
      />
    </view>
    <text class="identity-species">{{primary.nameCn}}</text>
    <text class="identity-title">{{primary.resultTitle}}</text>
    <text class="identity-line">{{primary.oneLineIdentity || primary.punchline}}</text>
    <view class="axis-chips">
      <text wx:for="{{paleoType.axisLabels}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="match-level">
      <text>{{matchLevel.label}}</text>
      <text>{{matchLevel.note}}</text>
    </view>
  </view>

  <view class="result-body">
    <view wx:if="{{sharedMode}}" class="shared-note">这是好友分享的身份卡，不含好友的答案和分数。完成 15 题后，你会看到自己的真实选择依据。</view>

    <view class="quadrant-section">
      <text class="section-kicker-global">YOUR PALEO PROFILE</text>
      <text class="section-heading-global">四格看懂这个结果</text>
      <view class="quadrant-grid">
        <view wx:for="{{quadrants}}" wx:key="key" class="quadrant-item quadrant-{{item.key}}" style="border-top-color:{{paleoType.color}}">
          <text>{{item.title}}</text>
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>

    <view class="result-section match-section">
      <text class="section-kicker-global">WHY THIS MATCH</text>
      <text class="section-heading-global">为什么会匹配到它</text>
      <view class="match-chain">
        <view class="chain-row">
          <text class="chain-label">你的真实选择</text>
          <text class="chain-copy">{{explanation.userEvidence}}</text>
        </view>
        <text class="chain-arrow">↓</text>
        <view class="chain-row">
          <text class="chain-label">古生物真实策略</text>
          <text class="chain-copy">{{explanation.creatureStrategy}}</text>
        </view>
        <text class="chain-arrow">↓</text>
        <view class="chain-row">
          <text class="chain-label">可类比共同机制</text>
          <text class="chain-copy">{{explanation.sharedMechanism}}</text>
        </view>
      </view>
      <view wx:if="{{topChoices.length}}" class="choice-receipts">
        <view wx:for="{{topChoices}}" wx:key="questionId">
          <text>第{{item.questionNumber}}题</text>
          <text>“{{item.selectedOptionText}}”</text>
          <text>{{item.insight}}</text>
        </view>
      </view>
    </view>

    <view class="result-section takeaway-section">
      <text class="section-kicker-global">USE IT TODAY</text>
      <text class="section-heading-global">把这张卡带回现代</text>
      <view class="takeaway-row">
        <text>现代类比</text>
        <text>{{primary.modernAnalogy || primary.modernRole}}</text>
      </view>
      <view class="takeaway-row">
        <text>生存提醒</text>
        <text>{{primary.survivalLesson}}</text>
      </view>
    </view>

    <view class="result-section science-section">
      <text class="section-kicker-global">SCIENCE PREVIEW</text>
      <text class="section-heading-global">科学底牌</text>
      <text class="science-intro">结果页只放最关键的三件事，完整文章留在科学档案里。</text>
      <view class="science-preview-list">
        <view>
          <text>一项真实生态事实</text>
          <text>{{sciencePreview.ecology}}</text>
        </view>
        <view>
          <text>一项关键证据</text>
          <text>{{sciencePreview.evidence}}</text>
        </view>
        <view>
          <text>一项主要不确定性</text>
          <text>{{sciencePreview.uncertainty}}</text>
        </view>
      </view>
      <view class="evidence-boundary">
        <text>我们凭什么这样复原</text>
        <text>{{explanation.evidenceBoundary}}</text>
      </view>
      <view wx:if="{{evidenceSources.length}}" class="source-links">
        <button wx:for="{{evidenceSources}}" wx:key="id" bindtap="copySource" data-url="{{item.url}}">
          <text>{{item.organization}}</text>
          <text>复制来源</text>
        </button>
      </view>
      <button class="primary-button science-button" bindtap="openCreature" data-id="{{primary.id}}">打开完整科学档案</button>
    </view>

    <view class="result-section calculation-section">
      <button class="calculation-toggle" bindtap="toggleCalculation">
        <text>计算说明</text>
        <text>{{showCalculation ? '收起' : '展开'}}</text>
      </button>
      <view wx:if="{{showCalculation}}" class="calculation-detail">
        <text wx:if="{{showMatch}}" class="entertainment-score">娱乐相似度 {{match}} / 100</text>
        <text wx:else class="entertainment-score">分享链接不传播娱乐分</text>
        <text class="calculation-note">这是依据 15 道场景题生成的娱乐分类，不是心理诊断，也没有测量古生物的性格。</text>
        <view class="dimension-groups">
          <view wx:for="{{dimensionGroups}}" wx:key="key">
            <view><text>{{item.label}}</text><text>{{item.note}}</text></view>
            <view class="result-track"><view style="width:{{item.value}}%;background:{{paleoType.color}}"></view></view>
          </view>
        </view>
      </view>
    </view>

    <view class="result-section nearby-section">
      <text class="section-kicker-global">NEARBY MATCHES</text>
      <text class="section-heading-global">两个相近结果</text>
      <view class="similar-grid">
        <view wx:for="{{similar}}" wx:key="id" hover-class="tap-card-active" bindtap="openCreature" data-id="{{item.id}}">
          <view class="similar-art">
            <media-image media-id="{{item.mediaId}}" variant="thumbnail" ratio="4:3" alt="{{item.nameCn}}艺术复原" placeholder-theme="rock" show-caption="{{false}}" show-meta="{{false}}" show-source="{{false}}" />
          </view>
          <view class="similar-heading"><text>{{item.nameCn}}</text><text>{{item.typeCode}}</text></view>
          <text class="similar-shared">{{item.shared}}</text>
          <text class="similar-difference">{{item.difference}}</text>
        </view>
      </view>
    </view>

    <view class="result-actions">
      <button class="share-button" bindtap="generatePoster" loading="{{posterGenerating}}">生成身份海报</button>
      <button class="share-button secondary-share" open-type="share">发送结果给好友</button>
      <button class="secondary-button" bindtap="openAtlas">浏览全部古生物</button>
      <button class="secondary-button" bindtap="retake">重新测试</button>
    </view>
    <text class="result-disclaimer">身份分类用于科普娱乐；古生物生态事实、复原证据与现代人的类比已分区呈现。</text>
  </view>
  <canvas type="2d" id="resultPoster" class="poster-canvas" style="width:750px;height:1200px"></canvas>
</view>
