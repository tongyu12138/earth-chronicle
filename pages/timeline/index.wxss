.page {
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 7%, rgba(72, 190, 166, 0.14), transparent 24%),
    radial-gradient(circle at 8% 32%, rgba(232, 150, 92, 0.08), transparent 22%),
    #071319;
}

.hero {
  position: relative;
  box-sizing: border-box;
  min-height: 920rpx;
  padding: 86rpx 52rpx 48rpx;
  overflow: hidden;
}

.orbit {
  position: absolute;
  border: 1rpx solid rgba(183, 226, 212, 0.12);
  border-radius: 50%;
  transform: rotate(-18deg);
}

.orbit-one {
  width: 680rpx;
  height: 260rpx;
  top: 72rpx;
  right: -210rpx;
}

.orbit-two {
  width: 480rpx;
  height: 180rpx;
  top: 132rpx;
  right: -92rpx;
}

.planet {
  position: absolute;
  width: 330rpx;
  height: 330rpx;
  top: 28rpx;
  right: -50rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(145deg, #2a857f, #123c4c 58%, #081b28);
  box-shadow: -30rpx 24rpx 80rpx rgba(22, 132, 123, 0.28), inset -52rpx -34rpx 70rpx rgba(0, 0, 0, 0.34);
}

.planet-glow {
  position: absolute;
  inset: -12rpx;
  border: 2rpx solid rgba(145, 231, 209, 0.3);
  border-radius: 50%;
}

.continent {
  position: absolute;
  border-radius: 48% 52% 62% 38%;
  background: rgba(170, 196, 115, 0.62);
  transform: rotate(-22deg);
  filter: blur(1rpx);
}

.continent-one {
  width: 118rpx;
  height: 78rpx;
  top: 86rpx;
  left: 54rpx;
}

.continent-two {
  width: 82rpx;
  height: 126rpx;
  top: 174rpx;
  right: 58rpx;
  transform: rotate(28deg);
}

.eyebrow,
.section-kicker,
.closing-kicker {
  position: relative;
  z-index: 2;
  color: #69cdb7;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.hero-title {
  position: relative;
  z-index: 2;
  width: 420rpx;
  margin-top: 196rpx;
  font-family: Georgia, "Songti SC", serif;
  font-size: 88rpx;
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  position: relative;
  z-index: 2;
  width: 590rpx;
  margin-top: 30rpx;
  color: #a9bbb7;
  font-size: 30rpx;
  line-height: 1.75;
}

.hero-stats {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 58rpx;
  padding: 30rpx 24rpx;
  border-top: 1rpx solid rgba(217, 239, 232, 0.12);
  border-bottom: 1rpx solid rgba(217, 239, 232, 0.12);
}

.stat {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  color: #f0f7f3;
  font-family: Georgia, serif;
  font-size: 34rpx;
}

.stat-label {
  margin-top: 10rpx;
  color: #758b86;
  font-size: 20rpx;
}

.stat-divider {
  width: 1rpx;
  height: 52rpx;
  background: rgba(217, 239, 232, 0.12);
}

.scroll-cue {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 44rpx;
  color: #708781;
  font-size: 22rpx;
}

.scroll-line {
  width: 58rpx;
  height: 1rpx;
  background: #4aa995;
}

.filter-panel {
  position: sticky;
  z-index: 20;
  top: 0;
  padding: 22rpx 0 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(7, 19, 25, 0.94);
  backdrop-filter: blur(18rpx);
}

.filter-heading { padding: 0 34rpx 18rpx; display: flex; align-items: center; gap: 18rpx; }
.filter-heading > view:first-child { flex: 1; display: flex; flex-direction: column; gap: 5rpx; }
.filter-heading > view:first-child text:first-child { color: #dce9e5; font-size: 24rpx; font-weight: 750; }
.filter-heading > view:first-child text:last-child { color: #6f8688; font-size: 18rpx; }
.mode-switch { display: flex; padding: 4rpx; border-radius: 16rpx; background: rgba(255,255,255,.05); }
.mode-switch button { min-width: 0; margin: 0; padding: 10rpx 13rpx; border-radius: 12rpx; color: #72898b; font-size: 17rpx; line-height: 1.2; }
.mode-switch button.active { background: rgba(101,212,193,.15); color: #74d9c7; }
.mode-switch button::after, .era-chip::after, .period-chip::after { border: 0; }

.era-nav {
  width: 100%;
  white-space: nowrap;
}

.era-nav-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 36rpx;
}

.era-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 15rpx 22rpx;
  border: 1rpx solid rgba(230, 245, 239, 0.12);
  border-radius: 999rpx;
  color: #b8c9c4;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.035);
}

.era-chip.selected { border-color: rgba(101,212,193,.45); background: rgba(101,212,193,.12); color: #ddf3ed; }

.era-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.period-nav { width: 100%; margin-top: 14rpx; white-space: nowrap; }
.period-nav-inner { display: inline-flex; gap: 11rpx; padding: 0 36rpx; }
.period-chip { min-width: 0; margin: 0; padding: 11rpx 17rpx; border: 1rpx solid; border-radius: 12rpx; background: rgba(255,255,255,.025); color: #718789; font-size: 19rpx; line-height: 1.3; }
.period-chip.selected { background: rgba(255,255,255,.09); color: #edf7f4; }

.timeline-intro {
  display: flex;
  flex-direction: column;
  padding: 100rpx 52rpx 76rpx;
}

.section-title {
  margin-top: 20rpx;
  color: #eef7f3;
  font-family: Georgia, "Songti SC", serif;
  font-size: 48rpx;
  line-height: 1.35;
}

.section-copy {
  margin-top: 24rpx;
  color: #819690;
  font-size: 25rpx;
  line-height: 1.8;
}

.timeline {
  position: relative;
  padding: 0 34rpx 30rpx;
}

.timeline-spine {
  position: absolute;
  top: 8rpx;
  bottom: 0;
  left: 66rpx;
  width: 2rpx;
  background: linear-gradient(to bottom, rgba(102, 202, 180, 0.5), rgba(224, 159, 93, 0.45), rgba(126, 167, 233, 0.5));
}

.era-marker {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  min-height: 110rpx;
  margin: 58rpx 0 18rpx;
  padding-left: 8rpx;
}

.era-marker:first-of-type {
  margin-top: 0;
}

.era-marker-line {
  width: 48rpx;
  height: 1rpx;
  margin-right: 20rpx;
  background: rgba(218, 239, 232, 0.22);
}

.era-marker-pill {
  padding: 10rpx 18rpx;
  border: 1rpx solid;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  background: #071319;
}

.era-marker-range {
  margin-left: 16rpx;
  color: #60736f;
  font-size: 20rpx;
}

.event-row {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0 28rpx;
}

.event-node {
  position: relative;
  z-index: 3;
  flex: 0 0 auto;
  box-sizing: border-box;
  width: 26rpx;
  height: 26rpx;
  margin: 48rpx 26rpx 0 19rpx;
  border: 2rpx solid;
  border-radius: 50%;
  background: #071319;
}

.event-node-core {
  position: absolute;
  top: 7rpx;
  left: 7rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.event-card {
  flex: 1;
  padding: 0;
  overflow: hidden;
  border: 1rpx solid rgba(226, 242, 236, 0.1);
  border-radius: 22rpx;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.025));
  box-shadow: 0 18rpx 50rpx rgba(0, 0, 0, 0.13);
  transition: transform 0.15s ease, background 0.15s ease;
}

.event-media { position: relative; width: 100%; }
.period-color-bar { width: 100%; height: 5rpx; }
.event-card-body { padding: 26rpx 28rpx 28rpx; }

.event-card-active {
  transform: scale(0.985);
  background: rgba(255, 255, 255, 0.085);
}

.card-topline,
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category {
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.card-arrow {
  color: #647b75;
  font-size: 30rpx;
}

.event-time {
  margin-top: 20rpx;
  color: #80948f;
  font-family: Georgia, serif;
  font-size: 22rpx;
}

.event-title {
  margin-top: 10rpx;
  color: #f0f7f4;
  font-family: Georgia, "Songti SC", serif;
  font-size: 37rpx;
  line-height: 1.35;
}

.event-summary {
  display: -webkit-box;
  margin-top: 18rpx;
  overflow: hidden;
  color: #9aada8;
  font-size: 24rpx;
  line-height: 1.7;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.card-footer {
  justify-content: flex-start;
  gap: 16rpx;
  margin-top: 26rpx;
  color: #718780;
  font-size: 20rpx;
}

.footer-line {
  width: 36rpx;
  height: 2rpx;
  opacity: 0.65;
}

.timeline-empty { margin: 30rpx 20rpx 60rpx 70rpx; padding: 34rpx; border: 1rpx dashed rgba(255,255,255,.13); border-radius: 22rpx; color: #748b8c; font-size: 22rpx; line-height: 1.6; text-align: center; }

.now-node {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 54rpx 0 0 19rpx;
  color: #83a59c;
  font-size: 22rpx;
}

.now-core {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #071319;
  border-radius: 50%;
  background: #77a8f1;
  box-shadow: 0 0 0 2rpx #77a8f1, 0 0 32rpx rgba(119, 168, 241, 0.5);
}

.now-pulse {
  position: absolute;
  left: -11rpx;
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid rgba(119, 168, 241, 0.25);
  border-radius: 50%;
}

.closing {
  display: flex;
  flex-direction: column;
  margin: 120rpx 34rpx 30rpx;
  padding: 64rpx 42rpx;
  border: 1rpx solid rgba(119, 168, 241, 0.15);
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(54, 91, 132, 0.18), rgba(21, 51, 60, 0.1));
}

.closing-kicker {
  color: #77a8f1;
}

.closing-title {
  margin-top: 20rpx;
  font-family: Georgia, "Songti SC", serif;
  font-size: 46rpx;
}

.closing-copy {
  margin-top: 20rpx;
  color: #8da19b;
  font-size: 25rpx;
  line-height: 1.8;
}
.closing-actions { width: 100%; margin-top: 38rpx; display: flex; flex-direction: column; gap: 14rpx; }
.closing-actions button { min-height: 84rpx; border-radius: 999rpx; background: rgba(101,212,193,.1); border: 1rpx solid rgba(101,212,193,.26); color: #69d0be; font-size: 22rpx; display: flex; align-items: center; justify-content: center; }
