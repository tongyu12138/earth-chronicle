.science-page { padding-bottom: 40rpx; }
.science-hero { position: relative; min-height: 1040rpx; padding: 72rpx 44rpx 54rpx; display: flex; flex-direction: column; align-items: center; overflow: hidden; text-align: center; }
.science-hero::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 260rpx; background: linear-gradient(transparent, #071319); pointer-events: none; }
.star-field { position: absolute; inset: 0; opacity: .7; background-image: radial-gradient(circle, rgba(255,255,255,.8) 0 1rpx, transparent 2rpx); background-size: 74rpx 74rpx; }
.star-two { transform: translate(28rpx, 20rpx) scale(.7); opacity: .35; }
.earth-stage { width: 500rpx; height: 500rpx; position: relative; display: flex; align-items: center; justify-content: center; z-index: 1; }
.earth-glow { position: absolute; width: 360rpx; height: 360rpx; border-radius: 50%; background: rgba(67,193,178,.3); filter: blur(34rpx); }
.earth-sphere { position: relative; width: 310rpx; height: 310rpx; border-radius: 50%; overflow: hidden; background: radial-gradient(circle at 30% 26%, #6bc5c6 0 10%, #237c91 36%, #0a4056 70%, #05161f 100%); box-shadow: inset -42rpx -30rpx 70rpx rgba(0,0,0,.72), 0 0 70rpx rgba(74,195,180,.25); animation: earthBreath 7s ease-in-out infinite; }
.earth-land { position: absolute; background: linear-gradient(140deg, #80a967, #315e48); opacity: .82; border-radius: 55% 35% 50% 40%; }
.land-a { width: 130rpx; height: 86rpx; left: 40rpx; top: 70rpx; transform: rotate(18deg); }
.land-b { width: 92rpx; height: 142rpx; right: 36rpx; bottom: 44rpx; transform: rotate(-24deg); }
.earth-shade { position: absolute; inset: 0; border-radius: 50%; background: linear-gradient(90deg, transparent 45%, rgba(0,0,0,.46)); animation: earthTurn 14s linear infinite; }
.orbit-ring { position: absolute; width: 450rpx; height: 250rpx; border: 1rpx solid rgba(120,222,211,.26); border-radius: 50%; transform: rotate(-18deg); }
.hero-eyebrow { z-index: 2; color: #6ed5c3; font-size: 20rpx; letter-spacing: 5rpx; font-weight: 700; }
.hero-number { z-index: 2; margin-top: 18rpx; font-size: 74rpx; line-height: 1.1; font-weight: 900; letter-spacing: -3rpx; }
.hero-title { z-index: 2; margin-top: 22rpx; font-size: 36rpx; font-weight: 800; }
.hero-copy { z-index: 2; max-width: 620rpx; margin-top: 22rpx; color: #9eb4b7; font-size: 27rpx; line-height: 1.75; }
.hero-button { z-index: 2; width: 360rpx; margin-top: 38rpx; gap: 20rpx; }
.hero-stats { z-index: 2; width: 100%; margin-top: 48rpx; display: flex; justify-content: center; border-top: 1rpx solid rgba(255,255,255,.08); padding-top: 30rpx; }
.hero-stats > view { flex: 1; display: flex; flex-direction: column; align-items: center; border-right: 1rpx solid rgba(255,255,255,.08); }
.hero-stats > view:last-child { border: 0; }
.stat-number { font-size: 38rpx; font-weight: 850; }
.stat-label { margin-top: 8rpx; color: #73898e; font-size: 20rpx; }
.top-tools, .section-block { padding: 0 32rpx; }
.search-entry { height: 94rpx; padding: 0 28rpx; border: 1rpx solid rgba(255,255,255,.1); border-radius: 26rpx; background: rgba(255,255,255,.045); display: flex; align-items: center; gap: 18rpx; color: #81979c; font-size: 25rpx; }
.search-entry text:nth-child(2) { flex: 1; }
.continue-card { margin-top: 20rpx; padding: 28rpx; border-radius: 26rpx; background: linear-gradient(135deg, rgba(91,207,187,.16), rgba(65,98,133,.12)); border: 1rpx solid rgba(105,218,198,.26); display: flex; align-items: center; }
.continue-card > view:first-child { flex: 1; display: flex; flex-direction: column; }
.continue-kicker { color: #65d4c1; font-size: 17rpx; letter-spacing: 3rpx; }
.continue-title { margin-top: 10rpx; font-size: 29rpx; font-weight: 750; }
.continue-arrow { font-size: 40rpx; color: #65d4c1; }
.categories-section { padding-top: 92rpx; }
.category-grid { margin-top: 36rpx; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.category-card { min-height: 230rpx; padding: 26rpx; border-radius: 26rpx; background: linear-gradient(145deg, rgba(255,255,255,.07), rgba(255,255,255,.025)); border: 1rpx solid rgba(255,255,255,.08); display: flex; flex-direction: column; }
.category-icon { width: 58rpx; height: 58rpx; border-radius: 18rpx; background: rgba(101,212,193,.13); color: #72dcc8; display: flex; align-items: center; justify-content: center; font-size: 30rpx; }
.category-name { margin-top: 24rpx; font-size: 29rpx; font-weight: 760; }
.category-copy { margin-top: 10rpx; color: #7f9599; font-size: 21rpx; line-height: 1.45; }
.daily-wrap { margin: 92rpx 32rpx 0; overflow: hidden; border-radius: 34rpx; background: #10242b; border: 1rpx solid rgba(255,255,255,.09); }
.daily-visual { height: 390rpx; display: flex; align-items: center; justify-content: center; }
.daily-image, .period-image { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 1; }
.daily-silhouette { z-index: 1; color: rgba(255,255,255,.2); font-size: 190rpx; font-weight: 900; }
.daily-badge { position: absolute; z-index: 2; left: 24rpx; top: 24rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: rgba(7,19,25,.72); backdrop-filter: blur(12rpx); font-size: 20rpx; }
.daily-content { padding: 34rpx; display: flex; flex-direction: column; }
.daily-time { color: #67d5c1; font-size: 21rpx; }
.daily-name { margin-top: 12rpx; font-size: 44rpx; font-weight: 850; }
.daily-latin { margin-top: 6rpx; color: #879da1; font-size: 22rpx; font-style: italic; }
.daily-copy { margin-top: 24rpx; color: #b4c4c5; font-size: 25rpx; line-height: 1.75; }
.text-button { margin-top: 28rpx; align-self: flex-start; color: #6dd8c4; font-size: 25rpx; font-weight: 700; }
.period-explorer { padding-top: 106rpx; }
.period-intro { display: block; margin-top: 24rpx; color: #7f969a; font-size: 24rpx; line-height: 1.7; }
.era-group { margin-top: 72rpx; }
.era-heading { display: flex; align-items: stretch; margin-bottom: 28rpx; }
.era-line { width: 7rpx; border-radius: 8rpx; margin-right: 18rpx; }
.era-heading > view:last-child { display: flex; flex-direction: column; }
.era-name { font-size: 34rpx; font-weight: 820; }
.era-meta { margin-top: 6rpx; color: #6f8589; font-size: 20rpx; }
.period-card { margin-bottom: 28rpx; overflow: hidden; border-radius: 30rpx; background: rgba(255,255,255,.045); border: 1rpx solid; }
.period-art { height: 300rpx; display: flex; align-items: center; justify-content: center; }
.period-icon { position: relative; z-index: 2; font-size: 105rpx; color: rgba(255,255,255,.52); }
.period-representative { position: absolute; z-index: 3; bottom: 22rpx; left: 24rpx; padding: 9rpx 16rpx; border-radius: 999rpx; background: rgba(4,15,20,.68); color: #c4d3d2; font-size: 19rpx; }
.period-info { padding: 30rpx; display: flex; flex-direction: column; }
.period-top { display: flex; align-items: center; }
.period-name { flex: 1; font-size: 40rpx; font-weight: 850; }
.period-arrow { color: #7a9296; font-size: 32rpx; }
.period-english { margin-top: 4rpx; color: #6ed5c2; font-size: 20rpx; letter-spacing: 1rpx; }
.period-range { margin-top: 20rpx; color: #e0c38c; font-size: 22rpx; font-weight: 650; }
.period-tagline { margin-top: 18rpx; color: #a6b7b9; font-size: 25rpx; line-height: 1.65; }
.period-footer { margin-top: 26rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,.07); display: flex; justify-content: space-between; color: #6f858a; font-size: 20rpx; }
.science-note { margin: 90rpx 32rpx 20rpx; padding: 28rpx; border-left: 4rpx solid #5bc6b4; background: rgba(255,255,255,.035); display: flex; flex-direction: column; gap: 12rpx; color: #7e9497; font-size: 22rpx; line-height: 1.65; }
.science-note text:first-child { color: #d7e5e1; font-weight: 750; }
@keyframes earthBreath { 0%,100% { transform: scale(1); } 50% { transform: scale(1.035); } }
@keyframes earthTurn { from { transform: translateX(-20rpx); } to { transform: translateX(28rpx); } }
@media (prefers-reduced-motion: reduce) { .earth-sphere, .earth-shade { animation: none; } }
