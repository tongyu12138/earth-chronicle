.science-page { padding-bottom: 50rpx; }
.science-hero { position:relative; min-height:1060rpx; padding:64rpx 40rpx 48rpx; display:flex; flex-direction:column; align-items:center; overflow:hidden; text-align:center; }
.science-hero::after { content:''; position:absolute; left:0; right:0; bottom:0; height:240rpx; background:linear-gradient(transparent,#071319); pointer-events:none; }
.star-field { position:absolute; inset:0; opacity:.6; background-image:radial-gradient(circle,rgba(255,255,255,.75) 0 1rpx,transparent 2rpx); background-size:74rpx 74rpx; }
.star-two { transform:translate(28rpx,20rpx) scale(.7); opacity:.3; }
.earth-stage { width:510rpx; height:510rpx; position:relative; display:flex; align-items:center; justify-content:center; z-index:1; }
.earth-glow { position:absolute; width:360rpx; height:360rpx; border-radius:50%; background:rgba(67,193,178,.3); filter:blur(36rpx); }
.earth-media { position:relative; z-index:2; width:316rpx; height:316rpx; border-radius:50%; overflow:hidden; box-shadow:inset -30rpx -25rpx 55rpx rgba(0,0,0,.4),0 0 70rpx rgba(74,195,180,.3); animation:earthBreath 7s ease-in-out infinite; }
.orbit-ring { position:absolute; width:460rpx; height:260rpx; border:1rpx solid rgba(120,222,211,.28); border-radius:50%; transform:rotate(-18deg); }
.hero-eyebrow { z-index:2; color:#6ed5c3; font-size:20rpx; letter-spacing:5rpx; font-weight:700; }
.hero-number { z-index:2; margin-top:18rpx; font-size:74rpx; line-height:1.1; font-weight:900; letter-spacing:-3rpx; }
.hero-title { z-index:2; margin-top:20rpx; font-size:36rpx; font-weight:800; }
.hero-copy { z-index:2; max-width:620rpx; margin-top:20rpx; color:#9eb4b7; font-size:27rpx; line-height:1.72; }
.hero-button { z-index:2; width:360rpx; margin-top:34rpx; gap:20rpx; }
.hero-stats { z-index:2; width:100%; margin-top:44rpx; display:flex; justify-content:center; border-top:1rpx solid rgba(255,255,255,.08); padding-top:28rpx; }
.hero-stats>view { flex:1; display:flex; flex-direction:column; align-items:center; border-right:1rpx solid rgba(255,255,255,.08); }
.hero-stats>view:last-child { border:0; }.stat-number{font-size:38rpx;font-weight:850}.stat-label{margin-top:8rpx;color:#73898e;font-size:20rpx}
.hero-credit { position:relative; z-index:3; margin-top:22rpx; color:#5f777d; font-size:18rpx; }
.top-tools,.section-block { padding-left:32rpx; padding-right:32rpx; }
.search-entry { height:94rpx; padding:0 28rpx; border:1rpx solid rgba(255,255,255,.1); border-radius:26rpx; background:rgba(255,255,255,.045); display:flex; align-items:center; gap:18rpx; color:#81979c; font-size:25rpx; }
.search-entry text:nth-child(2){flex:1}.continue-card{margin-top:20rpx;padding:28rpx;border-radius:26rpx;background:linear-gradient(135deg,rgba(91,207,187,.16),rgba(65,98,133,.12));border:1rpx solid rgba(105,218,198,.26);display:flex;align-items:center}.continue-card>view{flex:1;display:flex;flex-direction:column}.continue-kicker{color:#65d4c1;font-size:17rpx;letter-spacing:3rpx}.continue-title{margin-top:10rpx;font-size:29rpx;font-weight:750}.continue-arrow{font-size:40rpx;color:#65d4c1}
.daily-section,.era-section,.featured-section,.extinction-section,.lens-section,.final-ctas { padding-top:96rpx; }
.daily-card { margin-top:34rpx; overflow:hidden; border-radius:32rpx; border:1rpx solid rgba(255,255,255,.09); background:#10242b; display:grid; grid-template-columns:42% 58%; }
.daily-visual { min-height:430rpx; background:#102831; }.daily-content{padding:32rpx 28rpx;display:flex;flex-direction:column;justify-content:center}.daily-time{color:#67d5c1;font-size:20rpx}.daily-name{margin-top:12rpx;font-size:40rpx;font-weight:850}.daily-latin{margin-top:5rpx;color:#879da1;font-size:20rpx;font-style:italic}.daily-copy{margin-top:22rpx;color:#b4c4c5;font-size:23rpx;line-height:1.66}.inline-link{display:block;margin-top:24rpx;color:#6dd8c4;font-size:22rpx;font-weight:700}
.section-copy { display:block; margin-top:20rpx; max-width:660rpx; color:#7f969a; font-size:24rpx; line-height:1.7; }
.era-tabs,.period-strip,.event-strip,.extinction-strip { width:calc(100% + 32rpx); margin-top:34rpx; }.era-tabs-inner,.period-strip-inner,.event-strip-inner,.extinction-strip-inner{display:flex;gap:18rpx;padding-right:32rpx}
.era-tab{flex:0 0 250rpx;min-height:190rpx;padding:24rpx;border-radius:24rpx;border:1rpx solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);display:flex;flex-direction:column}.era-tab.is-active{background:linear-gradient(145deg,rgba(71,176,158,.18),rgba(255,255,255,.035))}.era-icon{font-size:38rpx;color:#65d4c1}.era-tab-name{margin-top:18rpx;font-size:28rpx;font-weight:800}.era-tab-range{margin-top:10rpx;color:#71898e;font-size:19rpx;line-height:1.45}
.selected-era-heading{margin-top:42rpx;display:flex}.selected-era-line{width:7rpx;border-radius:8rpx;margin-right:18rpx}.selected-era-heading>view:last-child{display:flex;flex-direction:column}.selected-era-heading text:first-child{font-size:34rpx;font-weight:820}.selected-era-heading text:last-child{margin-top:7rpx;color:#6f8589;font-size:20rpx}
.period-mini-card{flex:0 0 470rpx;overflow:hidden;border-radius:28rpx;background:rgba(255,255,255,.045);border:1rpx solid}.period-mini-art{position:relative}.period-mini-icon{position:absolute;z-index:3;left:24rpx;top:22rpx;font-size:60rpx;color:rgba(255,255,255,.76);text-shadow:0 4rpx 18rpx rgba(0,0,0,.6)}.period-mini-body{padding:26rpx;display:flex;flex-direction:column}.period-mini-name{font-size:36rpx;font-weight:850}.period-mini-en{margin-top:4rpx;color:#6ed5c2;font-size:19rpx}.period-mini-range{margin-top:16rpx;color:#e0c38c;font-size:21rpx}.period-mini-copy{margin-top:14rpx;min-height:76rpx;color:#a6b7b9;font-size:23rpx;line-height:1.58}.period-mini-footer{margin-top:20rpx;padding-top:18rpx;border-top:1rpx solid rgba(255,255,255,.07);display:flex;justify-content:space-between;color:#6f858a;font-size:19rpx}
.section-title-row{display:flex;align-items:flex-end;justify-content:space-between;gap:22rpx}.section-more{padding-bottom:4rpx;color:#6ed5c2;font-size:21rpx;white-space:nowrap}.event-feature-card{flex:0 0 500rpx;overflow:hidden;border-radius:28rpx;border:1rpx solid rgba(255,255,255,.08);border-top:5rpx solid;background:#10232a}.event-feature-body{padding:26rpx}.event-feature-meta{color:#6ed5c2;font-size:19rpx}.event-feature-title{display:block;margin-top:12rpx;font-size:32rpx;font-weight:820}.event-feature-copy{display:block;margin-top:14rpx;min-height:72rpx;color:#a6b7b9;font-size:22rpx;line-height:1.58}
.warning-kicker{color:#ef9a6f}.extinction-card{flex:0 0 330rpx;min-height:370rpx;padding:28rpx;border-radius:26rpx;border:1rpx solid rgba(225,117,78,.22);background:radial-gradient(circle at 86% 10%,rgba(203,87,50,.2),transparent 42%),#102027;display:flex;flex-direction:column}.extinction-number{color:#d77c58;font-size:50rpx;font-weight:900;opacity:.8}.extinction-title{margin-top:18rpx;font-size:31rpx;font-weight:820}.extinction-time{margin-top:10rpx;color:#e0b382;font-size:20rpx}.extinction-copy{margin-top:20rpx;color:#9fb0b2;font-size:22rpx;line-height:1.58}
.lens-grid{margin-top:34rpx;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18rpx}.lens-card{min-height:250rpx;padding:25rpx;border-radius:26rpx;border:1rpx solid rgba(255,255,255,.08);background:linear-gradient(145deg,rgba(255,255,255,.065),rgba(255,255,255,.025));display:flex;flex-direction:column}.lens-icon{width:58rpx;height:58rpx;border-radius:18rpx;background:rgba(101,212,193,.13);color:#72dcc8;display:flex;align-items:center;justify-content:center;font-size:30rpx}.lens-name{margin-top:22rpx;font-size:28rpx;font-weight:770}.lens-copy{margin-top:10rpx;color:#7f9599;font-size:21rpx;line-height:1.48}.lens-arrow{margin-top:auto;align-self:flex-end;color:#65d4c1;font-size:27rpx}
.final-ctas{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.atlas-cta,.quiz-cta{min-height:360rpx;padding:30rpx;border-radius:30rpx;display:flex;flex-direction:column}.atlas-cta{background:linear-gradient(145deg,#173b38,#10232a);border:1rpx solid rgba(100,212,193,.22)}.quiz-cta{background:linear-gradient(145deg,#273263,#171d3b);border:1rpx solid rgba(126,149,240,.24)}.cta-kicker{color:#65d4c1;font-size:17rpx;letter-spacing:2rpx}.quiz-cta .cta-kicker{color:#9caeff}.cta-title{margin-top:20rpx;font-size:32rpx;line-height:1.25;font-weight:850}.cta-copy{margin-top:16rpx;color:#98abad;font-size:22rpx;line-height:1.6}.cta-arrow{margin-top:auto;color:#78ddca;font-size:22rpx;font-weight:700}.quiz-cta .cta-arrow{color:#aebaff}
.science-note{margin:86rpx 32rpx 20rpx;padding:28rpx;border-left:4rpx solid #5bc6b4;background:rgba(255,255,255,.035);display:flex;flex-direction:column;gap:12rpx;color:#7e9497;font-size:22rpx;line-height:1.65}.science-note text:first-child{color:#d7e5e1;font-weight:750}
@keyframes earthBreath{0%,100%{transform:scale(1)}50%{transform:scale(1.035)}}
@media(prefers-reduced-motion:reduce){.earth-media{animation:none}}
